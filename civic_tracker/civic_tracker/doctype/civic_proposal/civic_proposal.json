{
    "name": "Civic Proposal",
    "module": "Civic Tracker",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "autoname": "format:PROPOSAL-{####}",
    "fields": [
        {
            "fieldname": "title",
            "fieldtype": "Data",
            "label": "Project Title",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "ward",
            "fieldtype": "Link",
            "label": "Ward",
            "options": "Municipal Ward",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "description",
            "fieldtype": "Text Editor",
            "label": "Project Description",
            "reqd": 1
        },
        {
            "fieldname": "estimated_budget",
            "fieldtype": "Currency",
            "label": "Estimated Budget",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Draft\nOpen for Voting\nApproved\nRejected",
            "default": "Draft",
            "in_list_view": 1
        },
        {
            "fieldname": "total_votes",
            "fieldtype": "Int",
            "label": "Total Votes",
            "read_only": 1,
            "in_list_view": 1,
            "default": "0"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        }
    ]
}
