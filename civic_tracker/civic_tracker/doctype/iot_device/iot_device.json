{
    "name": "IoT Device",
    "module": "Civic Tracker",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "autoname": "field:mac_address",
    "fields": [
        {
            "fieldname": "mac_address",
            "fieldtype": "Data",
            "label": "MAC Address",
            "reqd": 1,
            "unique": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "device_type",
            "fieldtype": "Select",
            "label": "Device Type",
            "options": "Smart Bin\nFlood Sensor\nAir Quality Monitor\nStreet Light Controller",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "ward",
            "fieldtype": "Link",
            "label": "Ward",
            "options": "Municipal Ward",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "location_details",
            "fieldtype": "Small Text",
            "label": "Location Details"
        },
        {
            "fieldname": "latitude",
            "fieldtype": "Float",
            "label": "Latitude"
        },
        {
            "fieldname": "longitude",
            "fieldtype": "Float",
            "label": "Longitude"
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Active\nInactive\nMaintenance",
            "default": "Active",
            "in_list_view": 1
        },
        {
            "fieldname": "last_ping",
            "fieldtype": "Datetime",
            "label": "Last Ping",
            "read_only": 1
        },
        {
            "fieldname": "last_payload",
            "fieldtype": "Code",
            "label": "Last Payload",
            "options": "JSON",
            "read_only": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        }
    ]
}
