{
    "name": "Municipal Tenant",
    "module": "Civic Tracker",
    "doctype": "DocType",
    "document_type": "Document",
    "istable": 1,
    "engine": "InnoDB",
    "fields": [
        {
            "fieldname": "municipality_name",
            "fieldtype": "Data",
            "label": "Municipality Name",
            "in_list_view": 1,
            "reqd": 1
        },
        {
            "fieldname": "site_name",
            "fieldtype": "Data",
            "label": "Site Domain (e.g. pune.civic.local)",
