            "reqd": 1
        },
        {
            "fieldname": "admin_email",
            "fieldtype": "Data",
            "label": "Admin Email",
            "reqd": 1
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Pending Provisioning\nActive\nSuspended",
            "default": "Pending Provisioning",
            "in_list_view": 1
        }
    ]
}
