{
    "name": "Issue SLA",
    "module": "Civic Tracker",
    "doctype": "DocType",
    "document_type": "Document",
    "engine": "InnoDB",
    "autoname": "field:sla_name",
    "title_field": "sla_name",
    "fields": [
        {
            "fieldname": "sla_name",
            "fieldtype": "Data",
            "label": "SLA Name",
            "reqd": 1,
            "unique": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "issue_type",
            "fieldtype": "Select",
            "label": "Issue Type",
            "options": "Road\\nWater\\nSanitation\\nElectricity\\nGarbage\\nDrainage\\nStreet Light\\nOther",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "sla_hours",
            "fieldtype": "Int",
            "label": "SLA Time (Hours)",
            "reqd": 1,
            "default": 48,
            "in_list_view": 1,
            "description": "Maximum time allowed to resolve this type of issue"
        },
        {
            "fieldname": "escalation_hours",
            "fieldtype": "Int",
            "label": "Escalation Time (Hours)",
            "reqd": 1,
            "default": 72,
            "description": "Time after which issue is escalated to higher authority"
        },
        {
            "fieldname": "column_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "is_active",
            "fieldtype": "Check",
            "label": "Is Active",
            "default": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "priority",
            "fieldtype": "Select",
            "label": "Default Priority",
            "options": "Low\\nMedium\\nHigh\\nCritical",
            "default": "Medium"
        },
        {
            "fieldname": "section_break_escalation",
            "fieldtype": "Section Break",
            "label": "Escalation Recipients"
        },
        {
            "fieldname": "ward_commissioner_email",
            "fieldtype": "Data",
            "label": "Ward Commissioner Email",
            "options": "Email",
            "description": "Email for first-level escalation"
        },
        {
            "fieldname": "column_break_esc",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "district_magistrate_email",
            "fieldtype": "Data",
            "label": "District Magistrate Email",
            "options": "Email",
            "description": "Email for second-level escalation"
        },
        {
            "fieldname": "section_break_notes",
            "fieldtype": "Section Break",
            "label": "Description"
        },
        {
            "fieldname": "description",
            "fieldtype": "Small Text",
            "label": "Description"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        },
        {
            "role": "Civic Admin",
            "read": 1,
            "write": 1,
            "create": 1
        }
    ]
}
